# Flip to "false" once real backend APIs are ready.
# This is the single switch for the mock/real interceptor.
NEXT_PUBLIC_USE_MOCK_API=true

# Base URL of the real backend (used when USE_MOCK_API=false)
NEXT_PUBLIC_API_BASE_URL=https://api.bunzo.zm/v1

# Payment provider keys (server-side only — never expose with NEXT_PUBLIC_)
AIRTEL_MONEY_CLIENT_ID=
AIRTEL_MONEY_CLIENT_SECRET=
MTN_MOMO_API_KEY=
MTN_MOMO_USER_ID=
MTN_MOMO_SUBSCRIPTION_KEY=
